# Lolday operator-local secrets — copy to .lolday-secrets.env (chmod 600).
# This file is gitignored except for this .example. Fill values out-of-band.
#
# Loaded by: scripts/deploy.sh, scripts/recover-harbor.sh,
#            scripts/harbor-inventory.sh, scripts/fix-lolday-project-public.sh,
#            scripts/diag-backend-401.sh, scripts/phase6-pre-deploy-check.sh
# Also referenced by: charts/lolday/templates/monitoring/alertmanager-config-discord.yaml
#                     (operator wires the value into a K8s Secret out-of-band)

# Phase 6 — monitoring secrets
GRAFANA_ADMIN_PASSWORD=
PG_EXPORTER_PASSWORD=

# Phase 6 + Phase 10 — Cloudflare tunnel
CF_ENABLED=true
CF_TUNNEL_TOKEN=

# Phase 7.4 — Discord webhooks. Four channels:
#   - events: user-facing notifications (job completed/failed, build, trivy)
#   - warning / critical: Alertmanager alerts at the corresponding severity
#   - heartbeat (optional): positive ping every 5 min from the
#     `deadmans-switch` CronJob (Phase 11; Spidey Heartbeat channel).
#     If empty, deadmans-switch only POSTs on Watchdog-fail (to critical).
# All channels can point at the same Discord channel for low-volume setups.
DISCORD_WEBHOOK_URL_EVENTS=
DISCORD_WEBHOOK_URL_WARNING=
DISCORD_WEBHOOK_URL_CRITICAL=
DISCORD_WEBHOOK_URL_HEARTBEAT=

# Phase 3 / Phase 9.6 recovery — Harbor
HARBOR_ADMIN_PASSWORD=

# Phase 3 — postgres root password (passed to postgresql.auth.password
# via deploy.sh; Harbor and MLflow each get their own DB user).
PG_PASSWORD=

# P2 H-9 (2026-05-12) — redis sub-chart requires --requirepass; deploy.sh
# fails fast if missing. Generate with: openssl rand -base64 24
REDIS_PASSWORD=

# Phase 4 — MLflow tracking server's DB password (passed to mlflow.db.password
# via deploy.sh).
MLFLOW_DB_PASSWORD=

# Phase 3 / P3 — backend Fernet keys for encrypted columns. Whitespace-
# separated list of base64 keys; the FIRST key is active for encrypt, all
# keys are tried for decrypt. Rotate via app.scripts.rotate_fernet — see
# docs/runbooks/p3-fernet-rotation.md.
# Generate a single key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Renaming note: this was FERNET_KEY (singular) before P3. If you have a
# legacy single key, just set FERNET_KEYS=$YOUR_OLD_KEY — same value, plural
# variable name. No data migration required for deploy; rotation is a
# separate operator action.
FERNET_KEYS=

# Phase 10 — SSO admin email. The operator's IdP (Cloudflare Access)
# email. The one-time `phase10_sso_admin_email` Alembic migration uses
# this to rename the seeded admin row so the operator's first SSO login
# maps onto the existing owner_id. Kept out of values.yaml so the
# public chart does not embed operator-personal info; injected at deploy
# time via `--set backend.env.SSO_ADMIN_EMAIL=...` by scripts/deploy.sh.
SSO_ADMIN_EMAIL=

# Phase 11c / Phase 12 — Cloudflare Access service token (machine principal).
# Used to test svctoken auth via /users/me. See
# docs/phase-history/phase12.1-role-enum-bug.md.
# Different lifecycle from the rest of this file:
#   - Rotation cadence: rotate per migration cycle (Phase 11d guidance).
#   - Blast radius if leaked: machine-principal-only (Role.SERVICE_TOKEN: -1
#     is intentionally less privileged than any human role).
# Not consumed by any script automatically — sourced manually for debug.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Add new keys here as they are introduced. Keep the comment block above
# each one explaining which phase / consumer needs it.
