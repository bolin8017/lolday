# Helm — tarballs are re-fetched via `helm dependency update`
charts/lolday/charts/*.tgz
charts/lolday/*.tgz

# Python (future phases)
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/

# Node (future phases)
node_modules/
.next/

# TypeScript build artefacts
*.tsbuildinfo

# Frontend config build emit — vite/vitest/playwright/tailwind read the .ts
# directly via tsx/esbuild; the .js / .d.ts siblings are accidental output
# from running `tsc --build` over the configs and should never be committed.
frontend/playwright.config.js
frontend/playwright.config.d.ts
frontend/vite.config.js
frontend/vite.config.d.ts
frontend/vitest.config.js
frontend/vitest.config.d.ts
frontend/tailwind.config.js
frontend/tailwind.config.d.ts

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Secrets — NEVER commit
*.env
*.env.*
!*.env.example
**/secrets/
# Lolday Cloudflare Access app/policy JSON snapshots (audit backups, may contain IDs)
.lolday-cloudflare-access-backups/

# Superpowers brainstorm sessions
.superpowers/

# Git worktrees
.worktrees/
test.db
